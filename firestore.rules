rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // قواعد الحماية لمجموعة المستخدمين
    match /users/{userId} {
      // أي مستخدم مسجل يمكنه القراءة (لعرض الملفات الشخصية مثلاً)
      allow read: if request.auth != null;
      // فقط صاحب الحساب هو من يمكنه إنشاء أو تعديل بياناته
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // قواعد الحماية لمجموعة الأفلام (للإعجابات والمحفوظات)
    match /movies/{movieId} {
      // أي مستخدم مسجل يمكنه القراءة والكتابة (لعمل Like أو Save)
      allow read, write: if request.auth != null;
    }
    
    // قاعدة عامة احتياطية لأي مجموعة أخرى قد تضاف مستقبلاً
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
